# ---------------------------------------
# QDP-SAE Backend Environment (Example)
# ---------------------------------------

# Database
# Keep one consistent DB URL per environment.
DATABASE_URL=sqlite:///./backend/qkd.db

# Security
# Use at least 32 characters in production.
SECRET_KEY=change-this-to-a-long-random-secret-key-32chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (JSON array or comma-separated string supported)
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173"]
APP_ENV=development

# Optional rate limiting
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
SIMULATION_RATE_LIMIT_REQUESTS=10
SIMULATION_RATE_LIMIT_WINDOW_SECONDS=60

# API metadata
API_TITLE=Quantum Key Distribution API
API_VERSION=1.0.0
API_DESCRIPTION=Backend API for BB84 Quantum Key Distribution simulation

# QKD defaults
DEFAULT_KEY_LENGTH=50
DEFAULT_NOISE_LEVEL=5
DEFAULT_DETECTOR_EFFICIENCY=95
MAX_KEY_LENGTH=500
MIN_KEY_LENGTH=10

# Logging
LOG_LEVEL=INFO
# Supported: json or python logging format string
LOG_FORMAT=json
